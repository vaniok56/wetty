TITLE=terminal.cactuz.icu
PORT=3001
BASE=/
SSHAUTH=publickey
SSHKEY=/run/terminal-ssh/id_ed25519
KNOWNHOSTS=/run/terminal-ssh/known_hosts
TARGETS_FILE=/run/terminal-targets.json5
TUNNEL_TOKEN=

# ── Session persistence ──────────────────────────────────────────────────────
# A terminal session outlives the socket that created it. When your phone locks
# and the websocket dies, the PTY keeps running; reconnecting replays a snapshot
# of the terminal, including whatever was printed while you were away.
#
# How long a detached session survives with nobody attached. Default 12h.
SESSION_GRACE_MINUTES=720
# Rows the server-side headless terminal retains per session (memory driver).
SESSION_SCROLLBACK=5000
# Rows replayed into a reattaching client.
SESSION_SNAPSHOT_SCROLLBACK=1000
# Concurrent tabs per user, per host.
SESSION_MAX_TABS=4
# Hard cap on live sessions across the whole server.
SESSION_MAX_SESSIONS=12

# ── Web Push ─────────────────────────────────────────────────────────────────
# Optional. When a detached session rings the terminal bell (Claude Code does
# this when it finishes), the server pushes a notification. Leave the keys empty
# to disable push entirely; everything else still works.
#
# Generate with:  node -e "console.log(require('web-push').generateVAPIDKeys())"
VAPID_SUBJECT=mailto:you@example.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
