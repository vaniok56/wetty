// Optional. The Docker image runs without a config file and takes everything
// from the environment (see .env.example). Pass --conf conf/config.json5 to use
// this instead. Machines are always defined in conf/targets.json5, never here.
{
  ssh: {
    auth:       'publickey',   // 'publickey' or 'password'
    // pass:    'password',    // only with auth: 'password'; requires sshpass
    // key:     '',            // client private key; password-less and unauthenticated
    knownHosts: '/dev/null',   // a real path enables StrictHostKeyChecking=accept-new
    // config:  '/home/user/.ssh/config',  // see "-F" in ssh(1)
  },

  server: {
    base:  '/',                  // URL base to serve from
    port:  3001,
    host:  '0.0.0.0',
    title: 'terminal.cactuz.icu',
    allowIframe: false,          // false pins X-Frame-Options to sameorigin
  },

  // Session lifetime and push are environment-only; see .env.example.

  /*
  ssl: {
    key: 'ssl.key',
    cert: 'ssl.cert',
  }
  */
}
